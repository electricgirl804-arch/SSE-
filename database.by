import requests
import streamlit as st
from datetime import datetime
WEB_APP_URL = "PASTE_YOUR_GOOGLE_SCRIPT_URL_HERE"

def save_to_sheet(data, sheet_type):
    data["التاريخ"] = datetime.now().strftime("%Y-%m-%d %H:%M")
    data["النوع"] = sheet_type
    try:
        requests.post(WEB_APP_URL, json=data, timeout=10)
        return True
    except Exception as e:
        st.error(f"خطأ في الحفظ: {e}")
        return False
