# دالة انشاء PDF
def create_pdf(text):
    buffer = BytesIO()
    p = canvas.Canvas(buffer, pagesize=A4)
    width, height = A4
    y = height - 50
    
    p.setFont("Helvetica", 9)
    for line in text.split('\n'):
        if y < 50:
            p.showPage()
            p.setFont("Helvetica", 9)
            y = height - 50
        p.drawString(40, y, line)
        y -= 14
    
    p.save()
    buffer.seek(0)
    return buffer

