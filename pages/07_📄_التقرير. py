# دالة انشاء PDF بالعربي
def create_pdf_ar(text):
    buffer = BytesIO()
    p = canvas.Canvas(buffer, pagesize=A4)
    width, height = A4
    y = height - 50
    p.setFont(FONT, 12)
    
    for line in text.split('\n'):
        if y < 50:
            p.showPage()
            p.setFont(FONT, 12)
            y = height - 50
        p.drawRightString(width - 40, y, line) # كتابة من اليمين
        y -= 18
    
    p.save()
    buffer.seek(0)
    return buffer

