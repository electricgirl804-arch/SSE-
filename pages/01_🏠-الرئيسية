    if st.button("الدخول لحساب الكيبل", key="cable", use_container_width=True):
        st.switch_page("05_الكيبل.py")

col4, col5, col6 = st.columns(3)
with col4:
    if st.button("الحمايات والقواطع", key="protect", use_container_width=True):
        st.switch_page("06_الحمايات.py")
with col5:
    if st.button("التقرير الفني PDF", key="report", use_container_width=True):
        st.switch_page("07_التقرير.py")
with col6:
    if st.button("حساب التكلفة", key="cost", use_container_width=True):
        st.switch_page("10_التكلفة.py")

