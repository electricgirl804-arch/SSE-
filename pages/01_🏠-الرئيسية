# الهيدر
col1, col2 = st.columns([1, 5])
with col1:
    st.image("logo.png", width=120)
with col2:
    st.markdown('<div class="header-text"><h1>⚡ SSE Smart Solar Platform</h1><p>منصة المهندسة شهد | تصميم أنظمة الطاقة الشمسية الذكية v2.0</p></div>', unsafe_allow_html=True)

st.divider()

# قسم الموقع وزاوية الميلان
st.markdown("<h2>🌍 بيانات الموقع والحسابات الأولية</h2>", unsafe_allow_html=True)

col1, col2, col3 = st.columns(3)
with col1:
    city = st.selectbox("اختيار المدينة", ["أم درمان", "الخرطوم", "بورتسودان", "عطبرة", "دنقلا", "واد مدني", "مخصص"])
with col2:
    season = st.selectbox("نمط التركيب", ["سنوي ثابت", "أقصى إنتاج صيفي", "أقصى إنتاج شتوي"])
with col3:
    custom_lat = st.number_input("خط العرض يدوي", value=15.65, format="%.2f", disabled=(city!= "مخصص"))

# خطوط العرض
latitudes = {
    "أم درمان": 15.65,
    "الخرطوم": 15.50,
    "بورتسودان": 19.62,
    "عطبرة": 17.71,
    "دنقلا": 19.17,
    "واد مدني": 14.40,
    "مخصص": custom_lat
}

latitude = latitudes[city]

# حساب زاوية الميلان المثلى
if season == "سنوي ثابت":
    tilt = latitude
elif season == "أقصى إنتاج صيفي":
    tilt = max(5, latitude - 15)
else:
    tilt = latitude + 15

# معامل تصحيح الإشعاع
tilt_factor = math.cos(math.radians(tilt - latitude)) * 0.98 + 0.02
base_irradiance = 5.8 if city in ["أم درمان", "الخرطوم"] else 6.2 if city == "بورتسودان" else 6.0
irradiance = base_irradiance * tilt_factor

# عرض النتائج
col1, col2, col3, col4 = st.columns(4)
col1.metric("خط العرض", f"{latitude:.2f}°")
col2.metric("زاوية الميلان المثلى", f"{tilt:.1f}°")
col3.metric("الإشعاع الأساسي", f"{base_irradiance:.1f} kWh/m²/day")
col4.metric("الإشعاع الفعلي بعد الميلان", f"{irradiance:.2f} kWh/m²/day")

st.info(f"يُفضل تركيب الألواح بزاوية {tilt:.1f}° باتجاه الجنوب لضمان أقصى إنتاج سنوي في {city}")

st.divider()

